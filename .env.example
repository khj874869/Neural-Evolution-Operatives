# AI requests are always proxied through the game server. Never use a VITE_ variable for provider keys.

# Client matchmaking/API endpoint.
VITE_GAME_SERVER_URL=http://localhost:2567

# Private alpha defaults. Commerce stays hidden until a platform sandbox adapter is installed.
VITE_RELEASE_CHANNEL=alpha
VITE_ENABLE_COMMERCE=false
VITE_FEEDBACK_URL=

# Server configuration. Generate JWT_SECRET locally; never commit the value.
HOST=0.0.0.0
PORT=2567
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=
POSTGRES_PASSWORD=
DATABASE_URL=
REDIS_URL=redis://localhost:6379
RELEASE_CHANNEL=alpha
COMMIT_SHA=

# Optional external persona AI. Without a key, Deep Talk uses the local rules core.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
AI_DAILY_TURN_LIMIT=12
AI_TIMEOUT_MS=8000
AI_MODERATION_ENABLED=true
