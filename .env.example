# AI requests must be proxied through a trusted server. Never expose provider keys here.
VITE_AI_GATEWAY_URL=

# Client matchmaking/API endpoint.
VITE_GAME_SERVER_URL=http://localhost:2567

# Private alpha defaults. Commerce stays hidden until a platform sandbox adapter is installed.
VITE_RELEASE_CHANNEL=alpha
VITE_ENABLE_COMMERCE=false
VITE_FEEDBACK_URL=

# Server configuration. Change JWT_SECRET before any public deployment.
HOST=0.0.0.0
PORT=2567
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=development-only-change-me-before-production
DATABASE_URL=postgresql://neo:neo_local_password@localhost:5432/neural_evolution
REDIS_URL=redis://localhost:6379
RELEASE_CHANNEL=alpha
COMMIT_SHA=
