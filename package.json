{
  "name": "neural-evolution-operatives",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:all": "concurrently -k -n CLIENT,SERVER -c cyan,green \"npm:dev\" \"npm:dev:server\"",
    "build": "tsc --noEmit && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start:server": "node dist-server/server/src/index.js",
    "smoke:server": "node server/scripts/smoke.mjs",
    "smoke:alpha": "node server/scripts/alpha-load.mjs",
    "smoke:soak": "node server/scripts/soak.mjs",
    "mobile:add:android": "npm run build && cap add android",
    "mobile:sync": "npm run build && cap sync android",
    "mobile:open": "cap open android",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run --config vitest.config.ts",
    "test:server": "vitest run --config vitest.server.config.ts",
    "check": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit && npm run test && npm run test:server"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@colyseus/core": "^0.17.44",
    "@colyseus/redis-driver": "^0.17.7",
    "@colyseus/redis-presence": "^0.17.7",
    "@colyseus/schema": "^4.0.27",
    "@colyseus/sdk": "^0.17.43",
    "@colyseus/ws-transport": "^0.17.13",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "phaser": "^3.90.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "concurrently": "^9.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
